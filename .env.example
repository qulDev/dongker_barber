# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configuration
# Temukan di Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# PostgreSQL Connection String (untuk Prisma/direct connection jika diperlukan)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Midtrans Configuration
# Temukan di Midtrans Dashboard -> Settings -> Access Keys
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-your-client-key
MIDTRANS_SERVER_KEY=SB-Mid-server-your-server-key
MIDTRANS_IS_PRODUCTION=false # Set to true in production
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js # Gunakan https://app.midtrans.com/snap/snap.js di production

# Notification Configuration (Optional)
# Token Fonnte untuk WhatsApp (dapatkan di Fonnte Dashboard)
FONNTE_API_TOKEN=your-fonnte-token-here

# API Key Resend untuk E-Receipt Email (dapatkan di Resend Dashboard)
RESEND_API_KEY=re_your_resend_api_key_here
